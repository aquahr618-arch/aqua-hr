# Rename this file to  secrets.toml  for LOCAL testing.
# On Streamlit Community Cloud, paste these same lines into:
#   App  ->  Settings  ->  Secrets
#
# Get the URL from Supabase:
#   Project -> Connect -> ORMs/psql -> "Connection string" (URI).
# Replace [YOUR-PASSWORD] with your database password.

[db]
url = "postgresql://postgres.xxxxxxxx:[YOUR-PASSWORD]@aws-0-xx.pooler.supabase.com:6543/postgres"
